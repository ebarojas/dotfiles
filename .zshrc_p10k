# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Start SSH agent if not running
export SSH_AUTH_SOCK="$HOME/.ssh/agent.sock"
if [ -z "$SSH_AUTH_SOCK" ]; then
    eval "$(ssh-agent -s -a $SSH_AUTH_SOCK)" > /dev/null 2>&1 < /dev/null
fi

# Bob for nvim
export PATH="$HOME/.local/share/bob/nvim-bin:$PATH"

export PATH="$HOME/.local/bin:$HOME/dotfiles/bin:$PATH"

# For MOSH
export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8

# FZF
source <(fzf --zsh 2>/dev/null) 2>/dev/null

# Machine-specific overrides (local to each machine, not tracked in dotfiles)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# ls config for macOSs colours
alias ls='ls --color=auto'

# p10k: Homebrew (Apple Silicon) on macOS; git clone in $HOME on Linux
if [[ "$OSTYPE" == darwin* ]]; then
  source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme
else
  source ~/powerlevel10k/powerlevel10k.zsh-theme
fi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh. Load after the theme.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# History File Config
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt SHARE_HISTORY
setopt HIST_IGNORE_SPACE
setopt APPEND_HISTORY

# Alias for todo.txt-cli wrapper — active when the todo dir exists only.
if [[ -d "${TODO_DIR:-$HOME/todo}" ]]; then
    alias t="$HOME/dotfiles/bin/atodo.sh"
fi
